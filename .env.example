# =============================================================================
# LangAlpha Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys.
#
# Quick start (Docker): set the two required keys below, then `docker compose up`
# Everything else has sensible defaults that work out of the box.
# =============================================================================

# =============================================================================
# Recommended — unlock the full experience (but not required to get started)
# =============================================================================
# LangAlpha works with zero external keys: Docker provides sandbox execution,
# Yahoo Finance MCP servers provide free data (enable in agent_config.yaml),
# and LLM access comes from your own subscription via OAuth.

# Daytona Sandbox — persistent cloud sandboxes with cross-session workspaces
# Get a key at https://www.daytona.io/
# When set, the sandbox provider auto-detects to "daytona".
# When empty, falls back to "docker" (local Docker containers).
DAYTONA_API_KEY=

# Sandbox provider — auto-detected from DAYTONA_API_KEY if not set.
# Explicit values: "daytona" (hosted sandbox) or "docker" (local containers).
SANDBOX_PROVIDER=

# Financial Modeling Prep — high-quality financial data for tools and MCP servers
# Free tier available at https://site.financialmodelingprep.com/
# Without this key, enable Yahoo Finance MCP servers in agent_config.yaml for free data.
FMP_API_KEY=

# =============================================================================
# LLM API Keys — set one, or use BYOK via OAuth (Codex, Claude)
# =============================================================================
# The default model is configured in agent_config.yaml. Set the key for
# whichever provider you want to use, or leave all empty and connect your
# existing AI subscription (ChatGPT, Claude) via OAuth in the UI.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
MINIMAX_API_KEY=

# =============================================================================
# Web Search — at least one recommended for search tools
# =============================================================================
SERPER_API_KEY=
TAVILY_API_KEY=

# =============================================================================
# Optional Services
# =============================================================================

# Alpha Vantage (alternative financial data MCP server, disabled by default)
ALPHA_VANTAGE_API_KEY=

# GitHub Bot (agent self-improvement — disabled by default, set github.enabled in config.yaml)
# GITHUB_BOT_TOKEN=

# LangSmith Tracing (disabled by default — set LANGSMITH_TRACING=true to enable)
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=langalpha
# Trace filter: strip large base64 from traces to prevent timeout on upload.
# Set to false in dev to see full image/PDF content in LangSmith.
LANGSMITH_TRACE_FILTER=true
LANGSMITH_TRACE_FILTER_MIN_BYTES=1000

# =============================================================================
# Cloud Storage — for chart image uploads (optional)
# =============================================================================
# Provider is configured in config.yaml (storage.provider)

# --- AWS S3 ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=
# S3_REGION=us-east-1
# S3_PUBLIC_URL_BASE=https://d1234.cloudfront.net

# --- Cloudflare R2 ---
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL_BASE=https://cdn.yourdomain.com

# --- Alibaba Cloud OSS ---
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET_NAME=
# OSS_REGION=oss-cn-hangzhou
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# =============================================================================
# Auth — leave SUPABASE_URL empty to disable (recommended for local dev)
# =============================================================================
# Deployment mode: "oss" (no auth, local dev) or "platform" (full auth)
# HOST_MODE=oss

# When auth is disabled, this user ID is used for all requests
AUTH_USER_ID=local-dev-user

# Encryption key for API keys stored at rest (auto-generated by `make config`)
# Generate manually: openssl rand -hex 32
# BYOK_ENCRYPTION_KEY=

# Public base URL of this server (used in agent-generated URLs like preview links)
# Set to your public-facing URL in production (e.g. https://app.example.com)
# SERVER_BASE_URL=http://localhost:8000

# =============================================================================
# Infrastructure — controls whether Docker Compose starts PostgreSQL and Redis
# =============================================================================
# Set to "infra" to start PostgreSQL and Redis in Docker (default).
# Remove or leave empty to use your own database and Redis instances.
COMPOSE_PROFILES=infra

# =============================================================================
# Database
# =============================================================================
# DB_HOST is auto-set by docker-compose.yml (defaults to "postgres" service name).
# For host development (make dev), uncomment and set to localhost:
# DB_HOST=localhost
DB_TYPE=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=postgres

# =============================================================================
# Redis
# =============================================================================
# REDIS_URL is auto-set by docker-compose.yml (defaults to "redis" service name).
# For host development (make dev), uncomment and set:
# REDIS_URL=redis://:redis@localhost:6379/0
REDIS_PASSWORD=redis

# =============================================================================
# Checkpoint DB — defaults to the same Postgres above
# =============================================================================
# Uncomment to use a separate database for LangGraph checkpoints
# MEMORY_DB_HOST=localhost
# MEMORY_DB_PORT=5432
# MEMORY_DB_NAME=langalpha
# MEMORY_DB_USER=postgres
# MEMORY_DB_PASSWORD=postgres
